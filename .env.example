APP_ENV=development

# Dev local (hors Docker)
DATABASE_URL=postgresql+asyncpg://writing_user:writing_password@localhost:5430/writing_assistant
# Dev local (via docker compose) — remplacer localhost par db
# DATABASE_URL=postgresql+asyncpg://writing_user:writing_password@db:5432/writing_assistant


# ChromaDB HTTP — dev local (hors Docker)
CHROMA_HOST=localhost
CHROMA_PORT=8001
# Dev local (via docker compose) — remplacer localhost par chromadb et port par 8000
# CHROMA_HOST=chromadb
# CHROMA_PORT=8000

OIDC_ISSUER_URL=http://localhost:8080/realms/writting_assistant
# Optionnal
OIDC_AUDIENCE=

# LanguageTool HTTP
LANGUAGETOOL_HOST="localhost"
LANGUAGETOOL_PORT=8010

# S3 / MinIO — dev local (hors Docker)
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=writing-assistant
S3_PRESIGNED_EXPIRY=3600
# Dev local (via docker compose) — remplacer localhost par minio
# S3_ENDPOINT_URL=http://minio:9000
