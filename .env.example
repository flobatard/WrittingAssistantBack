APP_ENV=development

# SQLite (MVP) — pour PostgreSQL : postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./writing_assistant.db

# Répertoire de persistance ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Modèle d'embedding HuggingFace
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
