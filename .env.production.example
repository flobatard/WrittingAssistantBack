APP_ENV=production

# Registry (used by docker-compose.prod.yml to pull the api image)
REGISTRY=registry.vpn.h.fbatard.fr
IMAGE_TAG=latest

# Postgres — used by both the db service AND the DATABASE_URL below.
# Keep POSTGRES_PASSWORD and the password in DATABASE_URL synchronized.
POSTGRES_USER=writing_user
POSTGRES_PASSWORD=__CHANGE_ME__
POSTGRES_DB=writing_assistant
DATABASE_URL=postgresql+asyncpg://writing_user:@db:5432/writing_assistant

# ChromaDB (internal docker network)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# LanguageTool (internal docker network)
LANGUAGETOOL_HOST=languagetool
LANGUAGETOOL_PORT=8010

# OIDC — external, to fill
OIDC_ISSUER_URL=
OIDC_AUDIENCE=

# S3 — external, to fill
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_PRESIGNED_EXPIRY=3600
